# === .env.example ===
# Smart Truck Loading Optimization System (STLOS) - Environment Variables Template
#
# USAGE: Copy this file to .env and fill in the values
#
# Database
# DATABASE_URL=postgresql://stlos_user:stlos_pass@localhost:5432/stlos_db
# DIRECT_URL=postgresql://stlos_user:stlos_pass@localhost:5432/stlos_db
#
# Redis
# REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6379
# REDIS_CONNECT_TIMEOUT_MS=10000
# REDIS_RETRY_BASE_MS=500
# REDIS_RETRY_MAX_DELAY_MS=5000
# REDIS_RETRY_LIMIT=20
# SOCKET_REDIS_REATTACH_BASE_MS=2000
# SOCKET_REDIS_REATTACH_MAX_DELAY_MS=30000
#
# JWT / Sessions
# JWT_SECRET=your-super-secret-jwt-key-change-me
# ACCESS_TOKEN_EXPIRES_IN=15m
# JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
# JWT_REFRESH_EXPIRES_IN=30d
# COOKIE_SECURE=false
# COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=
# APP_BASE_URL=http://localhost:3000
#
# Node API
# NODE_ENV=development
# PORT=4000
# CORS_ORIGIN=http://localhost:3000
#
# Python ML Service
# PYTHON_ML_URL=http://localhost:8000
# PYTHON_ML_PORT=8000
# ML_REQUEST_TIMEOUT_MS=5000
#
# OSRM
# OSRM_URL=http://router.project-osrm.org
#
# MinIO (Object Storage)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=stlos-documents
#
# Email (Nodemailer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
# PASSWORD_RESET_TOKEN_TTL_HOURS=2
#
# Jobs
# JOBS_ENABLED=true
# BOOKING_TIMEOUT_CRON=*/15 * * * *
# ML_RETRAIN_CRON=0 2 * * 0
# GPS_SIMULATOR_ENABLED=true
#
# Frontend
# VITE_API_URL=http://localhost:4000/api
# VITE_SOCKET_URL=http://localhost:4000
