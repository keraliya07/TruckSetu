# ============================================================
# .env.example — STLOS (TruckSetu) Environment Variables
# ============================================================
# USAGE:
#   1. Copy this file  →  cp .env.example .env
#   2. Fill in any values marked with <CHANGE_ME>
#   3. All defaults below work for a local Docker-based setup
# ============================================================

# ─── Database (PostgreSQL) ──────────────────────────────────
# When using docker-compose.example.yml these match the postgres service
DATABASE_URL=postgresql://stlos_user:stlos_pass@localhost:5432/stlos_db
DIRECT_URL=postgresql://stlos_user:stlos_pass@localhost:5432/stlos_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_RETRY_BASE_MS=500
REDIS_RETRY_MAX_DELAY_MS=5000
REDIS_RETRY_LIMIT=20
SOCKET_REDIS_REATTACH_BASE_MS=2000
SOCKET_REDIS_REATTACH_MAX_DELAY_MS=30000

# ─── JWT / Authentication ──────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Cookies ───────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# ─── Node API ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# ─── Python ML Service ─────────────────────────────────────
PYTHON_ML_URL=http://localhost:8000
PYTHON_ML_PORT=8000
ML_REQUEST_TIMEOUT_MS=5000

# ─── OSRM (Routing) ───────────────────────────────────────
OSRM_URL=http://router.project-osrm.org

# ─── MinIO (Object Storage) ───────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=stlos-documents

# ─── Email (SMTP / Nodemailer) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_HOURS=2

# ─── Scheduled Jobs ───────────────────────────────────────
JOBS_ENABLED=true
BOOKING_TIMEOUT_CRON=*/15 * * * *
ML_RETRAIN_CRON=0 2 * * 0
GPS_SIMULATOR_ENABLED=true
BOOKING_TIMEOUT_HOURS=2
RETURN_LOAD_EXPIRY_HOURS=4
GPS_UPDATE_INTERVAL_MS=10000

# ─── Frontend (also used by docker-compose for Vite) ──────
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
