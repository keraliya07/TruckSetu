# === backend/.env.example ===
# Backend environment variables
#
# NODE_ENV=development
# PORT=4000
# CORS_ORIGIN=http://localhost:3000
#
# DATABASE_URL=postgresql://stlos_user:stlos_pass@localhost:5432/stlos_db
# DIRECT_URL=postgresql://stlos_user:stlos_pass@localhost:5432/stlos_db
# REDIS_URL=redis://localhost:6379
#
# JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
# ACCESS_TOKEN_EXPIRES_IN=15m
# JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters
# JWT_REFRESH_EXPIRES_IN=30d
# COOKIE_SECURE=false
# COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=
# APP_BASE_URL=http://localhost:3000
#
# PYTHON_ML_URL=http://localhost:8000
# OSRM_URL=http://localhost:5000
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
# PASSWORD_RESET_TOKEN_TTL_HOURS=2
#
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=stlos-documents
#
# BOOKING_TIMEOUT_HOURS=2
# RETURN_LOAD_EXPIRY_HOURS=4
# GPS_UPDATE_INTERVAL_MS=10000
