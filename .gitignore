# === .gitignore ===
# STLOS (TruckSetu)

# ─── Dependencies ───
node_modules/
__pycache__/
*.pyc
.venv/
venv/
env/

# ─── Environment (NEVER commit real secrets) ───
.env
.env.local
.env.production
.env.development
.env.staging
frontend/.env
ml-service/.env

# ─── Allow example files to be committed ───
!.env.example
!frontend/.env.example
!ml-service/.env.example

# ─── Docker (real compose may contain secrets) ───
docker-compose.yml
docker-compose.override.yml
!docker-compose.example.yml
osrm-data/

# ─── Build Output ───
dist/
build/
*.egg-info/

# ─── IDE ───
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ───
logs/
*.log
npm-debug.log*

# ─── Prisma ───
prisma/migrations/*
!prisma/migrations/.gitkeep

# ─── ML Models ───
ml-service/app/models/saved/
*.pkl
*.joblib

# ─── Uploaded files ───
uploads/

# ─── Coverage ───
coverage/
.nyc_output/
htmlcov/
